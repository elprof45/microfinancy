generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleUtilisateur {
  SUPER_ADMIN
  ADMIN_SOCIETE
  GERANT_AGENCE
  CAISSIER
  COLLECTEUR_ADC
  LECTEUR
}

enum TypeMouvement {
  VERSEMENT
  RETRAIT
  VIREMENT
  REMISE_CHEQUE
  PAIEMENT_FACTURE
  INTERETS
  FRAIS
  AJUSTEMENT
  AUTRE
}

enum SensMouvement {
  DEBIT
  CREDIT
}

enum StatutCaisse {
  OUVERTE
  FERMEE
  POINTAGE_EN_COURS
  POINTAGE_OK
  ECART
}

enum StatutTransaction {
  EN_ATTENTE
  VALIDE
  REJETE
  ANNULE
  REMBOURSE
}

model Societe {
  id            Int       @id @default(autoincrement())
  nom           String
  raisonSociale String?
  siren         String?   @unique
  email         String?
  telephone     String?
  adresse       String?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int? // → Utilisateur
  updatedBy Int?

  agences      Agence[]
  utilisateurs Utilisateur[]      @relation("SocieteUtilisateurs")
  parametres   ParametreSociete[]
}

model Agence {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  nom       String
  adresse   String?
  telephone String?
  zoneId    Int?
  societeId Int
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societe Societe @relation(fields: [societeId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id])

  caissiers         Utilisateur[]      @relation("AgenceCaissiers")
  collecteurs       Utilisateur[]      @relation("AgenceCollecteurs")
  clients           ClientEpargne[]
  comptes           Compte[]
  mouvementsEpargne MouvementEpargne[]
  etatsCaisses      EtatCaisse[]
  utilisateurs      Utilisateur[]
}

model Zone {
  id        Int     @id @default(autoincrement())
  nom       String
  code      String? @unique
  societeId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agences Agence[]
}

model Utilisateur {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  motDePasseHash String
  nom            String
  prenom         String?
  telephone      String?
  matricule      String?         @unique
  role           RoleUtilisateur @default(CAISSIER)
  societeId      Int?
  agenceId       Int? // null si admin société ou super-admin
  isActive       Boolean         @default(true)
  lastLogin      DateTime?
  deletedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societe Societe? @relation("SocieteUtilisateurs", fields: [societeId], references: [id])
  agence  Agence?  @relation(fields: [agenceId], references: [id], map: "Utilisateur_agenceId_fkey")

  agenceCaissier    Agence?            @relation("AgenceCaissiers", fields: [agenceId], references: [id], map: "Utilisateur_agenceId_caissier_fkey")
  agenceCollecteur  Agence?            @relation("AgenceCollecteurs", fields: [agenceId], references: [id], map: "Utilisateur_agenceId_collecteur_fkey")
  caissierEtats     EtatCaisse[]       @relation("CaissierEtats")
  mouvements        MouvementItem[]
  createdMouvements MouvementEpargne[] @relation("CreatedBy")
  auditLogs         AuditLog[]
}

model ClientEpargne {
  id            Int       @id @default(autoincrement())
  numeroClient  String    @unique
  nom           String
  prenom        String?
  telephone     String?
  email         String?
  adresse       String?
  dateNaissance DateTime?
  pieceIdentite String? // numéro CNI, passeport...
  agenceId      Int?
  deviseId      String    @default("XOF") // ou ta devise par défaut
  isActif       Boolean   @default(true)
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agence Agence? @relation(fields: [agenceId], references: [id])

  comptes    Compte[]
  mouvements MouvementEpargne[]
}

model Compte {
  id              Int       @id @default(autoincrement())
  numeroCompte    String    @unique
  typeCompte      String // "EPARGNE", "COURANT", "ADC", "TONTINE"...
  solde           Decimal   @default(0)
  soldeDisponible Decimal   @default(0)
  dateOuverture   DateTime  @default(now())
  dateCloture     DateTime?
  clientId        Int?
  agenceId        Int
  deviseId        String
  isActif         Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client ClientEpargne? @relation(fields: [clientId], references: [id])
  agence Agence         @relation(fields: [agenceId], references: [id])

  mouvements        MouvementItem[]
  mouvementEpargnes MouvementEpargne[]
}

model MouvementEpargne {
  id            Int               @id @default(autoincrement())
  reference     String            @unique
  type          TypeMouvement
  sens          SensMouvement
  montant       Decimal
  soldeAvant    Decimal
  soldeApres    Decimal
  dateMouvement DateTime          @default(now())
  statut        StatutTransaction @default(EN_ATTENTE)
  observations  String?
  agenceId      Int
  clientId      Int?
  compteId      Int?
  creeParId     Int
  valideParId   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agence  Agence         @relation(fields: [agenceId], references: [id])
  client  ClientEpargne? @relation(fields: [clientId], references: [id])
  compte  Compte?        @relation(fields: [compteId], references: [id])
  creePar Utilisateur    @relation("CreatedBy", fields: [creeParId], references: [id])
}

model EtatCaisse {
  id             Int          @id @default(autoincrement())
  caissierId     Int
  date           DateTime // date de la caisse (généralement journée)
  soldeInitial   Decimal
  totalRecettes  Decimal      @default(0)
  totalDepenses  Decimal      @default(0)
  soldeFinalTheo Decimal
  soldeFinalReel Decimal?
  ecart          Decimal?
  statut         StatutCaisse @default(OUVERTE)
  observations   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caissier Utilisateur @relation("CaissierEtats", fields: [caissierId], references: [id], onDelete: Cascade)

  mouvements MouvementItem[] @relation("MouvementsCaisse")
  agence     Agence?         @relation(fields: [agenceId], references: [id])
  agenceId   Int?
}

model MouvementItem {
  id           Int               @id @default(autoincrement())
  reference    String?
  type         String // "ESPECES", "CHEQUE", "VIREMENT", "MOBILE_MONEY"...
  sens         SensMouvement
  montant      Decimal
  date         DateTime
  etatCaisseId Int?
  compteId     Int?
  caissierId   Int?
  statut       StatutTransaction @default(VALIDE)

  createdAt DateTime @default(now())

  caissier   Utilisateur? @relation(fields: [caissierId], references: [id])
  compte     Compte?      @relation(fields: [compteId], references: [id])
  etatCaisse EtatCaisse?  @relation("MouvementsCaisse", fields: [etatCaisseId], references: [id])
}

model AuditLog {
  id            Int          @id @default(autoincrement())
  utilisateurId Int?
  action        String // "CREATE_MOUVEMENT", "FERMER_CAISSE", "VALIDER_TRANSACTION"...
  entite        String
  entiteId      Int?
  avant         Json?
  apres         Json?
  ip            String?
  userAgent     String?
  date          DateTime     @default(now())
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id])
}

model ParametreSociete {
  id          Int     @id @default(autoincrement())
  societeId   Int
  cle         String // "TAUX_INTERET_EPARGNE", "PLAfond_RETRAIT_JOUR", "COMMISSION_ADC"...
  valeur      String
  type        String // "DECIMAL", "INTEGER", "BOOLEAN", "STRING"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  societe Societe @relation(fields: [societeId], references: [id], onDelete: Cascade)

  @@unique([societeId, cle])
}
